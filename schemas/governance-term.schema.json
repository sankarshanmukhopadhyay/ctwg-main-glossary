{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glossary.trustoverip.org/schemas/governance-term.schema.json",
  "title": "Governance Executable Glossary Term",
  "description": "Schema for authoritative governance-executable glossary term YAML artifacts under glossary/terms/.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "term",
    "definition",
    "governance",
    "assurance",
    "control_plane"
  ],
  "properties": {
    "term": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "definition": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "see_also": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "source_file": {
      "type": "string"
    },
    "governance_profile": {
      "enum": [
        "core-operational",
        "governance-supporting",
        "descriptive"
      ]
    },
    "governance": {
      "type": "object",
      "required": [
        "authority_scope",
        "delegation_mode",
        "revocation_supported",
        "lifecycle_states",
        "execution_role",
        "control_plane_role",
        "enforcement_points"
      ],
      "properties": {
        "authority_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "access_decisioning",
              "assurance_and_audit",
              "credential_issuance",
              "delegation_and_scope",
              "governance_recognition",
              "policy_definition",
              "registry_management",
              "terminology_definition",
              "verification_and_reliance"
            ]
          },
          "uniqueItems": true
        },
        "delegation_mode": {
          "enum": [
            "direct",
            "direct_or_constrained"
          ]
        },
        "revocation_supported": {
          "type": "boolean"
        },
        "lifecycle_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "active",
              "deprecated",
              "documented",
              "proposed",
              "retired",
              "revoked",
              "suspended"
            ]
          },
          "uniqueItems": true
        },
        "execution_role": {
          "enum": [
            "design",
            "hybrid",
            "runtime"
          ]
        },
        "control_plane_role": {
          "enum": [
            "decision_plane_component",
            "reference_term"
          ]
        },
        "enforcement_points": {
          "type": "array",
          "items": {
            "enum": [
              "access_decision",
              "definition_approval",
              "delegation_grant",
              "issuance_decision",
              "policy_approval",
              "registration_decision",
              "reliance_decision",
              "revocation_decision"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "assurance": {
      "type": "object",
      "required": [
        "evidence_artifacts",
        "assurance_level_hint",
        "auditability"
      ],
      "properties": {
        "evidence_artifacts": {
          "type": "array",
          "items": {
            "enum": [
              "access_decision_log",
              "attestation",
              "audit_log",
              "definition_change_record",
              "delegation_record",
              "issuance_log",
              "policy_document",
              "registry_entry",
              "status_record",
              "verification_log"
            ]
          },
          "uniqueItems": true
        },
        "assurance_level_hint": {
          "enum": [
            "informative",
            "AL1+",
            "AL2+"
          ]
        },
        "auditability": {
          "enum": [
            "basic",
            "moderate",
            "high"
          ]
        }
      }
    },
    "control_plane": {
      "type": "object",
      "required": [
        "decision_points",
        "accountable_entity",
        "evidence_produced"
      ],
      "properties": {
        "decision_points": {
          "type": "array",
          "items": {
            "enum": [
              "access_decision",
              "definition_approval",
              "delegation_grant",
              "issuance_decision",
              "policy_approval",
              "registration_decision",
              "reliance_decision",
              "revocation_decision"
            ]
          },
          "uniqueItems": true
        },
        "accountable_entity": {
          "type": "string",
          "minLength": 1
        },
        "evidence_produced": {
          "type": "array",
          "items": {
            "enum": [
              "access_decision_log",
              "attestation",
              "audit_log",
              "definition_change_record",
              "delegation_record",
              "issuance_log",
              "policy_document",
              "registry_entry",
              "status_record",
              "verification_log"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "crosswalk": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
