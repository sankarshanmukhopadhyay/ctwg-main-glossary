    {
      "@id": "https://glossary.trustoverip.org/terms/accreditation",
      "term": "accreditation",
      "definition": "Formal declaration by an accrediting authority that an information system is approved to operate at an acceptable level of risk, based on the implementation of an approved set of technical, managerial, and procedural safeguards.",
      "authority_scope": [
        "governance_recognition"
      ],
