    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:trusted-third-party",
      "name": "trusted-third-party",
      "description": "In cryptography, a trusted third party (TTP) is an entity which facilitates interactions between two parties who both trust the third party; the third party reviews all critical transaction communications between the parties, based on the ease of creating fraudulent digital content. In TTP models, the relying parties use this trust to secure their own interactions. TTPs are common in any number of commercial transactions and in cryptographic digital transactions as well as cryptographic protocols, for example, a certificate authority (CA) would issue a digital certificate to one of two parties. The CA then becomes the TTP to that certificate's issuance. Likewise transactions that need a third party recordation would also need a third-party repository service of some kind.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "trusted-third-party",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "verification_and_reliance",
            "governance_recognition"
          ],
          "delegation_mode": "direct",
          "revocation_supported": true,
