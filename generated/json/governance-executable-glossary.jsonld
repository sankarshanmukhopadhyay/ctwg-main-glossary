    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:pseudonym",
      "name": "pseudonym",
      "description": "A pseudonym is a fictitious name that a person assumes for a particular purpose, which differs from their original or true name (orthonym). This also differs from a new name that entirely or legally replaces an individual's own. Many pseudonym holders use pseudonyms because they wish to remain anonymous, but anonymity is difficult to achieve and often fraught with legal issues.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "pseudonym",
      "subjectOf": {
