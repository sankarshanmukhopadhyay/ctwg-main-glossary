    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:blockchain",
      "name": "blockchain",
      "description": "A distributed ledger of cryptographically-signed transactions that are grouped into blocks. Each block is cryptographically linked to the previous one (making it tamper evident) after validation and undergoing a consensus decision. As new blocks are added, older blocks become more difficult to modify (creating tamper resistance). New blocks are replicated across copies of the ledger within the network, and any conflicts are resolved automatically using established rules.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "blockchain",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "policy_definition"
          ],
