    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:unicast",
      "name": "unicast",
      "description": "In computer networking, unicast is a one-to-one transmission from one point in the network to another point; that is, one sender and one receiver, each identified by a network address (a unicast address). Unicast is in contrast to multicast and broadcast which are one-to-many transmissions. Internet Protocol unicast delivery methods such as Transmission Control Protocol (TCP) and User Datagram Protocol (UDP) are typically used.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "unicast",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "terminology_definition"
          ],
          "delegation_mode": "direct",
          "revocation_supported": false,
