    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:keys-at-the-edge",
      "name": "keys-at-the-edge",
      "description": "A key management architecture in which keys are stored on a user\u2019s local edge devices, such as a smartphone, tablet, or laptop, and then used in conjunction with a secure protocol to unlock a key management system (KMS) and/or a digital vault in the cloud. This approach can enable the storage and sharing of large data structures that are not feasible on edge devices. This architecture can also be used in conjunction with confidential computing to enable cloud-based digital agents to safely carry out \u201cuser not present\u201d operations.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "keys-at-the-edge",
      "subjectOf": {
        "governance": {
