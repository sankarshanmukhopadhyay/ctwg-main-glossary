    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:broken-object-level-authorization",
      "name": "broken-object-level-authorization",
      "description": "Refers to security flaws where users can access data they shouldn't, due to inadequate permission checks on individual (sub)objects.",
      "inDefinedTermSet": "ToIP Main Glossary",
