    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:sybil-attack",
      "name": "sybil-attack",
      "description": "A Sybil attack is a type of attack on a computer network service in which an attacker subverts the service's reputation system by creating a large number of pseudonymous identities and uses them to gain a disproportionately large influence. It is named after the subject of the book _Sybil_, a case study of a woman diagnosed with dissociative identity disorder.",
      "inDefinedTermSet": "ToIP Main Glossary",
