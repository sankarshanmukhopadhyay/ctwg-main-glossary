    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:discovery",
      "name": "discovery",
      "description": "A mechanism that helps systems or devices find each other automatically, often used in networks to identify services or resources. In decentralized identifier systems it helps to locate and verify digital identities without relying on a central authority.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "discovery",
