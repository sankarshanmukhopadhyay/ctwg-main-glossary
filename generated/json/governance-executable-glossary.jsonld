    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:end-to-end-principle",
      "name": "end-to-end-principle",
      "description": "The end-to-end principle is a design framework in computer networking. In networks designed according to this principle, guaranteeing certain application-specific features, such as reliability and security, requires that they reside in the communicating end nodes of the network. Intermediary nodes, such as gateways and routers, that exist to establish the network, may implement these to improve efficiency but cannot guarantee end-to-end correctness.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "end-to-end-principle",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "policy_definition"
          ],
          "delegation_mode": "direct",
