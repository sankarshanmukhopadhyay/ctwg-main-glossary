      "name": "multi-signature",
      "description": "A cryptographic signature scheme where the process of signing information (e.g., a transaction) is distributed among multiple private keys.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "multi-signature",
      "subjectOf": {
