    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:digital-credential",
      "name": "digital-credential",
      "description": "A credential in digital form that is signed with a digital signature and held in a digital wallet. A digital credential is issued to a holder by an issuer; a proof of the credential is presented by the holder to a verifier.",
