    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:anycast",
      "name": "anycast",
      "description": "Anycast is a network addressing and routing methodology in which a single IP-address is shared by devices (generally servers) in multiple locations. Routers direct packets addressed to this destination to the location nearest the sender, using their normal decision-making algorithms, typically the lowest number of BGP network hops. Anycast routing is widely used by content delivery networks such as web and name servers, to bring their content closer to end users.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "anycast",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "terminology_definition"
          ],
          "delegation_mode": "direct",
          "revocation_supported": false,
          "lifecycle_states": [
            "documented",
            "active",
            "deprecated"
          ],
