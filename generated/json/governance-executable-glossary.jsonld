      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:public-key",
      "name": "public-key",
      "description": "In public key cryptography, the cryptographic key that can be freely shared with anyone by the controller without compromising security. A party's public key must be verified as authoritative in order to verify their digital signature.",
