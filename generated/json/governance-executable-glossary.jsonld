    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:custodial-wallet",
      "name": "custodial-wallet",
      "description": "A digital wallet that is directly in the custody of a principal, i.e., under the principal\u2019s direct personal or organizational control. A digital wallet that is in the custody of a third party is called a non-custodial wallet.",
