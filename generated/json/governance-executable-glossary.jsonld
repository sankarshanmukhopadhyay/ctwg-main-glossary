    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:zero-knowledge-service-provider",
      "name": "zero-knowledge-service-provider",
      "description": "The provider of a zero-knowledge service that hosts encrypted data on behalf of the principal but does not have access to the private keys in order to be able to decrypt it.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "zero-knowledge-service-provider",
