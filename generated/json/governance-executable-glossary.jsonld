    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:protocol-stack",
      "name": "protocol-stack",
      "description": "The protocol stack or network stack is an implementation of a computer networking protocol suite or protocol family. Some of these terms are used interchangeably but strictly speaking, the _suite_ is the definition of the communication protocols, and the _stack_ is the software implementation of them.",
