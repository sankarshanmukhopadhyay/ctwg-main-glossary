    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:zero-trust-architecture",
      "name": "zero-trust-architecture",
      "description": "A network security architecture based on the core design principle \u201cnever trust, always verify\u201d, so that all actors are denied access to resources pending verification.",
