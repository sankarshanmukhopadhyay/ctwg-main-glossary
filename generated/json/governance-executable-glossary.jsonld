      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:multicast-address",
      "name": "multicast-address",
      "description": "A multicast address is a logical identifier for a group of hosts in a computer network that are available to process datagrams or frames intended to be multicast for a designated network service.",
