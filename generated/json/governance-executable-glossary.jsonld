    {
      "@type": "DefinedTerm",
      "@id": "urn:toip:glossary:end-to-end-encryption",
      "name": "end-to-end-encryption",
      "description": "Encryption that is applied to a communication before it is transmitted from the sender\u2019s communication endpoint and cannot be decrypted until after it is received at the receiver\u2019s communication endpoint. When end-to-end encryption is used, the communication cannot be decrypted in transit no matter how many intermediaries are involved in the routing process.",
      "inDefinedTermSet": "ToIP Main Glossary",
      "identifier": "end-to-end-encryption",
      "subjectOf": {
        "governance": {
          "authority_scope": [
            "terminology_definition"
          ],
